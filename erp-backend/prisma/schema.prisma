generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// USERS & RBAC
enum UserRole {
  ADMIN
  STAFF
  MANAGER
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum NotificationType {
  ORDER_CREATED
  ORDER_STATUS_CHANGED
  PURCHASE_CREATED
  PURCHASE_STATUS_CHANGED
  PURCHASE_RECEIVED
}

enum NotificationEntityType {
  ORDER
  PURCHASE
  SYSTEM
}

model Tenant {
  id                   String       @id @default(uuid())
  name                 String
  slug                 String       @unique
  status               TenantStatus @default(ACTIVE)
  currencyCode         String       @default("USD")
  currencyLocale       String       @default("en-US")
  currencyExchangeRate Decimal      @default(1) @db.Decimal(12, 4)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  users             User[]
  warehouses        Warehouse[]
  products          Product[]
  inventoryItems    InventoryItem[]
  stockMovements    StockMovement[]
  orders            Order[]
  customers         Customer[]
  suppliers         Supplier[]
  purchases         Purchase[]
  notifications     Notification[]
  userNotifications UserNotification[]
  invites           TenantInvite[]
}

model Role {
  id    String   @id @default(uuid())
  name  UserRole @unique
  users User[]   @relation("UserRoles")
}

model User {
  id                   String             @id @default(uuid())
  tenantId             String
  name                 String?
  email                String             @unique
  isPlatformAdmin      Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  roles                Role[]             @relation("UserRoles")
  tenant               Tenant             @relation(fields: [tenantId], references: [id])
  createdNotifications Notification[]     @relation("NotificationActor")
  userNotifications    UserNotification[]
  createdInvites        TenantInvite[]     @relation("InviteCreator")

  @@index([tenantId])
}

model TenantInvite {
  id              String       @id @default(uuid())
  tenantId        String
  email           String
  name            String?
  role            UserRole
  tokenHash       String       @unique
  status          InviteStatus @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdByUserId String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  createdBy User   @relation("InviteCreator", fields: [createdByUserId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status, expiresAt])
  @@index([email])
}

model Notification {
  id              String                 @id @default(uuid())
  tenantId        String
  type            NotificationType
  title           String
  message         String
  entityType      NotificationEntityType @default(SYSTEM)
  entityId        String?
  createdByUserId String?
  createdAt       DateTime               @default(now())
  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  createdBy       User?                  @relation("NotificationActor", fields: [createdByUserId], references: [id])
  recipients      UserNotification[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model UserNotification {
  id             String       @id @default(uuid())
  tenantId       String
  notificationId String
  userId         String
  readAt         DateTime?
  archivedAt     DateTime?
  createdAt      DateTime     @default(now())
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([tenantId])
  @@index([tenantId, userId, readAt, archivedAt])
}

// INVENTORY
model Warehouse {
  id             String          @id @default(uuid())
  tenantId       String
  name           String
  location       String?
  description    String?
  inventoryItems InventoryItem[]
  stockMovements StockMovement[]
  purchases      Purchase[]
  createdAt      DateTime        @default(now())
  tenant         Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model Product {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  sku         String
  description String?
  category    String    @default("General")
  unit        String    @default("unit")
  minStock    Int       @default(10)
  price       Decimal   @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  inventoryItems InventoryItem[]
  stockMovements StockMovement[]
  orderItems     OrderItem[]
  purchaseItems  PurchaseItem[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model InventoryItem {
  id               String @id @default(uuid())
  tenantId         String
  productId        String
  warehouseId      String
  quantity         Int    @default(0)
  reservedQuantity Int    @default(0)

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, productId, warehouseId])
  @@index([tenantId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, productId])
}

model StockMovement {
  id          String            @id @default(uuid())
  tenantId    String
  productId   String
  warehouseId String
  quantity    Int
  type        StockMovementType
  reference   String?
  createdAt   DateTime          @default(now())

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@index([tenantId, type, createdAt])
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

// SALES / ORDERS
model Order {
  id          String      @id @default(uuid())
  tenantId    String
  status      OrderStatus @default(DRAFT)
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  totalAmount Decimal     @default(0) @db.Decimal(14, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
  tenant      Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
}

model OrderItem {
  id          String  @id @default(uuid())
  order       Order   @relation(fields: [orderId], references: [id])
  orderId     String
  product     Product @relation(fields: [productId], references: [id])
  productId   String
  warehouseId String  @default("main")
  quantity    Int
  price       Decimal @db.Decimal(12, 2)
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PICKED
  SHIPPED
  DELIVERED
  CANCELLED
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  email     String
  phone     String?
  address   String?
  orders    Order[]
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model Supplier {
  id        String     @id @default(uuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  address   String? // Added: Useful for generating PO documents
  purchases Purchase[]
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  createdAt DateTime   @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model Purchase {
  id            String         @id @default(uuid())
  tenantId      String
  purchaseOrder String
  supplierId    String
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  warehouseId   String
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  status        PurchaseStatus @default(DRAFT)
  totalAmount   Decimal        @default(0) @db.Decimal(14, 2)
  items         PurchaseItem[]
  receivedAt    DateTime? // Added: Track when inventory actually increased
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenant        Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, purchaseOrder])
  @@index([tenantId])
  @@index([tenantId, supplierId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  price      Decimal  @db.Decimal(12, 2) // This is the unit price at the time of purchase
}

enum PurchaseStatus {
  DRAFT
  CONFIRMED
  SHIPPED
  RECEIVED
  CANCELLED
}
